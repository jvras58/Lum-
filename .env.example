# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lum_dev

# Cron security (generate: openssl rand -hex 32)
SECRET_CRON_TOKEN=change_me_generate_with_openssl_rand_hex_32

# Email provider: nodemailer | console (default: console for local dev)
EMAIL_PROVIDER=console
EMAIL_FROM=no-reply@example.com

# SMTP (if EMAIL_PROVIDER=nodemailer)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=user@example.com
SMTP_PASS=your_smtp_password
